{
  "name": "BenzConfig", // Полное имя приложения, отображается, например, в списке установленных приложений

  "short_name": "BenzConfig", 
  // Короткое имя приложения, используется на иконках и в ограниченном пространстве

  "start_url": ".", 
  // URL, с которого приложение будет запускаться при открытии из ярлыка (точка = текущая папка)

  "display": "standalone", 
  // Режим отображения: standalone = приложение будет открываться без браузерного интерфейса (как нативное)

  "orientation": "portrait", 
  // Ориентация экрана при запуске: portrait = вертикальная

  "background_color": "#ffffff", 
  // Цвет фона, который отображается при загрузке приложения (экран загрузки)

  "theme_color": "#ffffff", 
  // Цвет темы для системных элементов (например, статус-бар на Android/iOS)

  "icons": [ 
    // Массив иконок приложения для разных целей
    {
      "src": "assets/icon-180.png", 
      // Путь к файлу иконки
      "sizes": "180x180", 
      // Размер иконки в пикселях
      "type": "image/png" 
      // Формат изображения
    }
  ]
}


